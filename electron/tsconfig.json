{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "./",
    "sourceMap": false,
    "declaration": false,
    "removeComments": true,
    "lib": ["ES2022"]
  },
  "include": ["main.ts", "preload.ts"]
}
