# Copy this file to .env and fill in your values

# Database
DATABASE_URL="file:./db/custom.db"

# Server
NODE_ENV="production"
PORT=3000
HOSTNAME=0.0.0.0

# Session Security — generate with: openssl rand -hex 32
SESSION_SECRET=""

# ============================================================
# Email — Resend API (PRIMARY, works on Railway/cloud)
# ============================================================
# Railway blocks outbound SMTP (ports 25/465/587/2525).
# Resend uses HTTPS port 443 — always allowed.
# Free tier: 3,000 emails/month, 100/day.
# Sign up at https://resend.com (no credit card needed).
RESEND_API_KEY=""
RESEND_FROM="BizBook Pro <onboarding@resend.dev>"

# ============================================================
# Email — SMTP (FALLBACK, only works in local dev)
# ============================================================
# Gmail requires an App Password (not your regular password).
# Create one: https://myaccount.google.com/apppasswords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="BizBook Pro <your-email@gmail.com>"

# SMS (2Factor.in)
TWOFACTOR_API_KEY=""
TWOFACTOR_SENDER_ID="BIZBOK"
TWOFACTOR_TEMPLATE_NAME="BizBook Pro"

# Multi-tenant auth bypass
MASTER_MOBILE_NUMBER="9101555075"
ADMIN_EMAIL="admin@bizbook.pro"

# UPI payments (zero-cost unique-paise tracking)
MASTER_UPI_VPA="9101555075@kotakbank"

# Razorpay (optional — leave empty for manual mode)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
