# Copy this file to .env and fill in your values

# Database
DATABASE_URL="file:./db/custom.db"

# Server
NODE_ENV="production"
PORT=3000
HOSTNAME=0.0.0.0

# Session Security — generate with: openssl rand -hex 32
SESSION_SECRET=""

# Email (SMTP via Gmail)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="BizBook Pro <your-email@gmail.com>"

# SMS (2Factor.in)
TWOFACTOR_API_KEY=""
TWOFACTOR_SENDER_ID="BIZBOK"
TWOFACTOR_TEMPLATE_NAME="BizBook Pro"

# Razorpay (optional — leave empty for manual mode)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
